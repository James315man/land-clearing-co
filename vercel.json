{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        { "source": "/angier-nc", "destination": "/angier-nc.html" },
        { "source": "/benson-nc", "destination": "/benson-nc.html" },
        { "source": "/clayton-nc", "destination": "/clayton-nc.html" },
        { "source": "/garner-nc", "destination": "/garner-nc.html" },
        { "source": "/selma-nc", "destination": "/selma-nc.html" },
        { "source": "/smithfield-nc", "destination": "/smithfield-nc.html" },
        { "source": "/johnston-county-nc", "destination": "/johnston-county-nc.html" },
        { "source": "/wake-county-nc", "destination": "/wake-county-nc.html" },
        { "source": "/harnett-county-nc", "destination": "/harnett-county-nc.html" },
        { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}